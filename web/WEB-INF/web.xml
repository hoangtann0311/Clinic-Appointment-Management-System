<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Clinic Appointment Management System</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 phút -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ============================================================
         Google OAuth 2.0 Configuration
         ============================================================
         Mỗi developer/máy chủ cần có Client ID riêng từ Google Cloud Console.

         Cách lấy:
         1. Vào https://console.cloud.google.com/
         2. Tạo project → "APIs & Services" → "Credentials"
         3. Tạo "OAuth 2.0 Client ID" (Web application)
         4. Thêm vào "Authorized JavaScript origins":
              - http://localhost
              - http://localhost:8080
              - http://localhost:8081   (thêm tất cả port bạn dùng)
         5. Thêm vào "Authorized redirect URIs":
              - http://localhost:8080/ClinicAppointmentManagementSystem/google-login-server
              - http://localhost:8081/ClinicAppointmentManagementSystem/google-login-server
              - (với từng port bạn dùng, context path tương ứng)
         6. Cấu hình bằng JVM properties hoặc environment variables:
              -Dgoogle.client.id=...
              -Dgoogle.client.secret=...
              GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
    -->
    <context-param>
        <param-name>google.client.id</param-name>
        <param-value>YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com</param-value>
        <description>Google OAuth 2.0 Client ID từ Google Cloud Console</description>
    </context-param>

    <context-param>
        <param-name>google.client.secret</param-name>
        <param-value>YOUR_GOOGLE_CLIENT_SECRET</param-value>
        <description>Google OAuth 2.0 Client Secret (chỉ dùng cho server-side flow)</description>
    </context-param>

    <!-- ============================================================
         FILTER ORDER
         ============================================================
         Tất cả filter dùng annotation @WebFilter, Tomcat thực thi
         theo thứ tự alphabetical của TÊN LỚP (class name).

         THỨ TỰ THỰC THI (Tomcat default — alphabetical):
         1. AuthenticationFilter — Kiểm tra đăng nhập + Active status
         2. AuthorizationFilter  — RBAC + Permission Check + Audit Log
         3. CsrfFilter          — Bảo vệ CSRF cho POST/PUT/DELETE
         4. EncodingFilter      — UTF-8 encoding
         5. SecurityHeadersFilter — Security headers (XSS, clickjack, etc.)

         LUỒNG XỬ LÝ ĐẦY ĐỦ:
         Request
         ├─ SecurityHeadersFilter: Set security headers
         ├─ EncodingFilter:       UTF-8 → pass
         ├─ CsrfFilter:           GET → tạo token | POST → validate token
         ├─ AuthenticationFilter: Public path? → pass
         │                        | No session? → redirect /login
         │                        | Not Active? → invalidate + redirect
         │                        | OK → pass
         └─ AuthorizationFilter:  Public path? → pass
                                  | Zone check → Role trong zone?
                                  | Whitelist check → URL có trong whitelist?
                                  | Permission check → Có permission key?
                                  | Session sync → Reload nếu role thay đổi
                                  | Audit Log → Ghi log truy cập
                                  | Default Deny → 403
                                  | OK → Controller
    -->

    <!-- ============================================================
         FILTER DECLARATIONS & MAPPINGS
         ============================================================
         Enforcing correct processing order:
         1. EncodingFilter (Sets request/response to UTF-8 before parameters are read)
         2. SecurityHeadersFilter (Adds security headers)
         3. CsrfFilter (CSRF protection)
         4. AuthenticationFilter (Login/Session checking)
         5. AuthorizationFilter (RBAC/Audit checking)
    -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.clinic.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>SecurityHeadersFilter</filter-name>
        <filter-class>com.clinic.filter.SecurityHeadersFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeadersFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>com.clinic.filter.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.clinic.filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>com.clinic.filter.AuthorizationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Error pages -->
    <error-page>
        <error-code>400</error-code>
        <location>/views/errors/400.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/views/errors/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/views/errors/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>409</error-code>
        <location>/views/errors/409.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/errors/500.jsp</location>
    </error-page>

    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
        </jsp-property-group>
    </jsp-config>

</web-app>
