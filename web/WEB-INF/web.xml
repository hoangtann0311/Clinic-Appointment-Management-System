<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Clinic Appointment Management System</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session timeout: 30 phút -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ============================================================
         Google OAuth 2.0 Configuration
         ============================================================
         Mỗi developer/máy chủ cần có Client ID riêng từ Google Cloud Console.

         Cách lấy:
         1. Vào https://console.cloud.google.com/
         2. Tạo project → "APIs & Services" → "Credentials"
         3. Tạo "OAuth 2.0 Client ID" (Web application)
         4. Thêm vào "Authorized JavaScript origins":
              - http://localhost
              - http://localhost:8080
              - http://localhost:8081   (thêm tất cả port bạn dùng)
         5. Thêm vào "Authorized redirect URIs":
              - http://localhost:8080/ClinicAppointmentManagementSystem/google-login-server
              - http://localhost:8081/ClinicAppointmentManagementSystem/google-login-server
              - (với từng port bạn dùng, context path tương ứng)
         6. Copy Client ID và dán vào giá trị bên dưới

         LƯU Ý: File này (web.xml) KHÔNG commit lên git để tránh lộ Client ID.
         Mỗi developer giữ bản web.xml riêng với Client ID của họ.
    -->
    <context-param>
        <param-name>google.client.id</param-name>
        <param-value>437305021332-tkk9gu93jltirvu07q9h9a27012a3eua.apps.googleusercontent.com</param-value>
        <description>Google OAuth 2.0 Client ID từ Google Cloud Console</description>
    </context-param>

    <context-param>
        <param-name>google.client.secret</param-name>
        <param-value>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</param-value>
        <description>Google OAuth 2.0 Client Secret (chỉ dùng cho server-side flow)</description>
    </context-param>

    <!-- ============================================================
         FILTER ORDER (annotation-based @WebFilter)
         ============================================================
         Thứ tự thực thi trong Tomcat (theo alphabetical class name):
         1. AuthenticationFilter (com.clinic.filter)
         2. AuthorizationFilter  (com.clinic.filter)
         3. EncodingFilter       (com.clinic.filter)

         LUỒNG XỬ LÝ:
         EncodingFilter:       UTF-8 → pass
         AuthenticationFilter: Public path? → pass | No session? → redirect /login
                               | Not Active? → invalidate + redirect | OK → pass
         AuthorizationFilter:  Public path? → pass | Zone check → Whitelist check
                               → Permission check → Audit Log → pass | Default Deny → 403

         NGHIỆP VỤ PHÂN QUYỀN (AuthorizationFilter):
         YC1: Tất cả role đều qua filter
         YC2: Whitelist theo Role + Permission
         YC3: Default Deny — mọi URL không trong whitelist → 403
         YC4: Chỉ Active user + session hợp lệ mới được truy cập
         YC5: Từ chối → HTTP 403 + trang Access Denied
         YC6: Audit Log: user, role, URL, action, time, IP, result
         YC7: Session Sync: phát hiện thay đổi role/permission → reload hoặc re-login
    -->

    <!-- Error pages -->
    <error-page>
        <error-code>403</error-code>
        <location>/views/errors/403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/views/errors/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/views/errors/500.jsp</location>
    </error-page>

</web-app>
